{
  "name": "url-shortener",
  "version": "1.0.0",
  "private": true,
  "description": "Tiny URL application built with React, Node.js, and TypeScript",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "worker:dev": "tsx watch src/worker/worker.ts",
    "frontend:dev": "vite --config frontend/vite.config.ts",
    "frontend:build": "cross-env NODE_ENV=production vite build --config frontend/vite.config.ts",
    "frontend:preview": "vite preview --config frontend/vite.config.ts",
    "build": "npm run build:server && npm run frontend:build",
    "build:server": "tsc -p tsconfig.build.json",
    "start": "node dist/api/server.js",
    "worker:start": "node dist/worker/worker.js",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs --follow",
    "docker:logs:frontend": "docker compose logs --follow frontend",
    "docker:logs:api": "docker compose logs --follow api",
    "docker:logs:worker": "docker compose logs --follow worker",
    "docker:mongo": "docker compose exec mongo mongosh url_shortener",
    "docker:redis": "docker compose exec redis redis-cli",
    "docker:rabbitmq": "docker compose exec rabbitmq rabbitmqctl list_queues name messages_ready messages_unacknowledged",
    "docker:ps": "docker compose ps",
    "typecheck": "tsc --noEmit && tsc -p frontend/tsconfig.json && tsc -p tests/frontend/tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.8",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "amqplib": "^2.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "redis": "^6.0.0",
    "zod": "^4.4.3"
  }
}
