{
  "name": "url-shortener",
  "version": "1.0.0",
  "private": true,
  "description": "Tiny URL backend built with Node.js and TypeScript",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/api/server.ts",
    "worker:dev": "tsx watch src/worker/worker.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/api/server.js",
    "worker:start": "node dist/worker/worker.js",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs --follow",
    "docker:logs:api": "docker compose logs --follow api",
    "docker:logs:worker": "docker compose logs --follow worker",
    "docker:mongo": "docker compose exec mongo mongosh url_shortener",
    "docker:redis": "docker compose exec redis redis-cli",
    "docker:rabbitmq": "docker compose exec rabbitmq rabbitmqctl list_queues name messages_ready messages_unacknowledged",
    "docker:ps": "docker compose ps",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.1.8",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "pino-pretty": "^13.1.3",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "amqplib": "^2.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "redis": "^6.0.0",
    "zod": "^4.4.3"
  }
}
