NODE_ENV=development
PORT=3000
FRONTEND_PORT=5173
APP_BASE_URL=http://localhost:3000
VITE_API_ORIGIN=http://localhost:3000
VITE_API_PROXY_TARGET=http://localhost:3000

MONGODB_URI=mongodb://localhost:27017/url_shortener
MONGO_PORT=27017

REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
REDIS_CACHE_TTL_SECONDS=86400

RABBITMQ_USER=change-me
RABBITMQ_PASSWORD=change-me
RABBITMQ_URL=amqp://change-me:change-me@localhost:5672
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_EXCHANGE=tinyurl.events
RABBITMQ_ACCESS_QUEUE=tinyurl.accessed.persist
RABBITMQ_PUBLISH_TIMEOUT_MS=1000

LOG_LEVEL=info
