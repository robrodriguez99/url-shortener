NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000

MONGODB_URI=mongodb://localhost:27017/url_shortener
MONGO_PORT=27017

REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
REDIS_CACHE_TTL_SECONDS=86400

RABBITMQ_USER=app
RABBITMQ_PASSWORD=app
RABBITMQ_URL=amqp://app:app@localhost:5672
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_EXCHANGE=tinyurl.events
RABBITMQ_ACCESS_QUEUE=tinyurl.accessed.persist

LOG_LEVEL=info
